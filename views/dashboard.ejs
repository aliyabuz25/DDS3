            </a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link" id="nav-catalogs-list">
              <i class="nav-icon fas fa-list"></i>
              <p data-i18n="catalogList">Catalog List</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link" id="nav-add-catalog">
              <i class="nav-icon fas fa-plus"></i>
              <p data-i18n="addCatalogItem">Add Catalog Item</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link" id="nav-security">
              <i class="nav-icon fas fa-shield-alt"></i>
