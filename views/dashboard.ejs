            </a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link" id="nav-payments">
              <i class="nav-icon fas fa-credit-card"></i>
              <p data-i18n="payments">Payments</p>
            </a>
          </li>
          <li class="nav-item">
            <a href="#" class="nav-link" id="nav-notifications">
              <i class="nav-icon fas fa-bell"></i>
