        <!-- Section 6: Payments List -->
        <div class="content-section d-none" id="payments-section">
          <div class="card card-success card-outline">
            <div class="card-header">
              <h3 class="card-title font-weight-bold text-dark m-0">
                <i class="fas fa-credit-card text-success mr-1"></i> <span data-i18n="payments">Payments</span>
              </h3>
            </div>
            <div class="card-body">
              <table id="paymentsTable" class="table table-bordered table-striped table-hover w-100">
                <thead>
                  <tr>
                    <th style="width: 50px;">ID</th>
                    <th>User ID</th>
                    <th data-i18n="email">Email</th>
                    <th data-i18n="productId">Product ID</th>
                    <th data-i18n="amount">Amount</th>
                    <th data-i18n="currency">Currency</th>
                    <th data-i18n="status">Status</th>
                    <th data-i18n="transactionId">Transaction ID</th>
                    <th style="width: 130px;" data-i18n="createdAt">Created At</th>
                  </tr>
                </thead>
                <tbody id="paymentsTableBody">
                  <!-- Loaded via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Section 7: Notifications List -->
        <div class="content-section d-none" id="notifications-section">
          <div class="row">
            <div class="col-md-4">
              <div class="card card-primary">
                <div class="card-header">
                  <h3 class="card-title font-weight-bold"><i class="fas fa-paper-plane mr-1"></i> <span data-i18n="sendNotification">Send Notification</span></h3>
                </div>
                <form id="sendNotificationForm">
                  <div class="card-body">
                    <div id="notification-alert"></div>
                    <div class="form-group">
                      <label for="notifTitle" class="font-weight-bold" data-i18n="notificationTitle">Notification Title</label>
                      <input type="text" class="form-control" id="notifTitle" required placeholder="Welcome!">
                    </div>
                    <div class="form-group">
                      <label for="notifMessage" class="font-weight-bold" data-i18n="notificationMessage">Notification Message</label>
                      <textarea class="form-control" id="notifMessage" rows="3" required placeholder="Message content..."></textarea>
                    </div>
                    <div class="form-group">
                      <label for="notifType" class="font-weight-bold" data-i18n="notificationType">Notification Type</label>
                      <select class="form-control" id="notifType">
                        <option value="info" selected>Info</option>
                        <option value="success">Success</option>
                        <option value="warning">Warning</option>
                        <option value="danger">Danger</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label for="notifSentTo" class="font-weight-bold" data-i18n="sentTo">Sent To</label>
                      <input type="text" class="form-control" id="notifSentTo" placeholder="all" value="all" required>
                    </div>
