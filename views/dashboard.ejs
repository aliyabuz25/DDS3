<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Bootstrap 4 -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.bundle.min.js"></script>
<!-- bs-custom-file-input -->
<script src="https://cdn.jsdelivr.net/npm/bs-custom-file-input/dist/bs-custom-file-input.min.js"></script>
<!-- AdminLTE App -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<!-- DataTables & Plugins -->
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap4.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.2.9/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.2.9/js/responsive.bootstrap4.min.js"></script>

<script>
  // Dynamic Localization Dictionary fetched from Endpoint
  let locales = {};
  let currentLang = localStorage.getItem('lang') || 'en';

  function applyLanguage(lang) {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    
    // Toggle active classes on dropdown buttons
    $('.lang-btn').removeClass('active');
    $(`.lang-btn[data-lang="${lang}"]`).addClass('active');

    if (!locales[lang]) return;

    // Update translations
    $('[data-i18n]').each(function() {
      const key = $(this).attr('data-i18n');
      if (locales[lang] && locales[lang][key] !== undefined) {
        $(this).text(locales[lang][key]);
      }
    });

    // Update placeholders and custom fields
    $('#catalogSearchInput').attr('placeholder', locales[lang].searchPublications);
    $('#catalogName').attr('placeholder', locales[lang].publicationNameLabel);
    $('#catalogDescription').attr('placeholder', locales[lang].descriptionSummaryLabel || locales[lang].descriptionSummaryLabel);

    // Refresh Active Sidebar text
    const activeText = $('.nav-sidebar .nav-link.active').find('p').attr('data-i18n');
    if (activeText && locales[lang][activeText]) {
      $('#pageTitle').text(locales[lang][activeText]);
      $('#breadcrumbActive').text(locales[lang][activeText]);
    }
  }

  function initLocalization() {
    $.ajax({
      url: '/api/locales',
      type: 'GET',
      success: function(data) {
        locales = data;
        applyLanguage(currentLang);
        loadCatalogs();
      },
      error: function(xhr) {
        console.error('Failed to load dictionary dynamically', xhr);
        // Fallback minimal dictionary
        locales = {
          en: {
            home: "Home", catalog: "Catalog", systemOperator: "System Operator", profile: "Profile", logout: "Logout",
            systemUser: "System User", dashboardOverview: "Dashboard Overview", catalogList: "Catalog List",
            addCatalogItem: "Add Catalog Item", securityShield: "Security Shield", totalCatalogItems: "Total Catalog Items",
            apiServiceStatus: "API Service Status", multipartUploadActive: "Multipart Upload Active", protectedLabel: "Protected",
            xssBruteforceShield: "XSS & Bruteforce Shield", viewDetails: "View Details", checkProtection: "Check Protection",
            uploadCover: "Upload Cover", securitySpecs: "Security Specs", welcomeTitle: "Visual Catalog System",
            welcomeText: "Welcome to the CMS Admin Console. This user-friendly interface allows you to easily manage, filter, and organize visual catalog publications.", browseCatalogList: "Browse Catalog List", addPublication: "Add Publication",
            registeredVisualPublications: "Registered Visual Publications", searchPublications: "Search...",
            id: "ID", publicationName: "Name", description: "Description", verticalCover: "Vertical Cover (3:4)",
            horizontalCover: "Horizontal Cover (16:9)", createdAt: "Created At", noPublicationsFound: "No publications found.",
            noPublicationsMatch: "No matching publications.", addNewVisualPublication: "Add Publication",
            publicationNameLabel: "Publication Name", descriptionSummaryLabel: "Description", verticalThumbnailCover: "Vertical Thumbnail Cover *",
            horizontalBannerCover: "Horizontal Banner Cover *", chooseVerticalImage: "Choose image...",
            chooseHorizontalImage: "Choose image...", verticalAspectRatio: "Vertical (3:4)", horizontalAspectRatio: "Horizontal (16:9)",
            noImageSelected: "No Image Selected", acceptsFormats: "Accepts formats.", saveUploadPublication: "Save & Upload",
            middlewareSecurityGuard: "Security Guard", helmetSecurity: "Helmet Security", helmetText: "Helmet protection.",
            rateLimiterShield: "Rate Limiter", rateLimiterText: "Rate limits active.", strictSanitizer: "Strict Sanitizer",
            strictSanitizerText: "XSS sanitizer active.", systemSchemaIntegration: "Schema specs", systemSchemaText: "Schema files."
          }
        };
        applyLanguage(currentLang);
        loadCatalogs();
      }
    });
  }

  // Section switcher helper
  function showSection(sectionId, navLinkId) {
    // Hide all sections
    $('.content-section').addClass('d-none');
    // Show active section
    $(`#${sectionId}`).removeClass('d-none');
    
    // Update active nav-link
    $('.nav-sidebar .nav-link').removeClass('active');
    $(`#${navLinkId}`).addClass('active');

    // Update titles & breadcrumbs
    const activeText = $(`#${navLinkId}`).find('p').attr('data-i18n');
    if (activeText && locales[currentLang] && locales[currentLang][activeText]) {
      $('#pageTitle').text(locales[currentLang][activeText]);
      $('#breadcrumbActive').text(locales[currentLang][activeText]);
    }
  }

  $(document).ready(function() {
    // Initialize file input labels
    bsCustomFileInput.init();

    // Check token
    const token = localStorage.getItem('token');
    const user = JSON.parse(localStorage.getItem('user'));
    
    if (!token || !user) {
      window.location.href = '/login';
      return;
    }

    // Dynamic Avatar generation via UI-Avatars for clean standard alignment
    const firstName = user.firstName || 'Admin';
    const lastName = user.lastName || 'User';
    const cleanFirstName = $('<div/>').html(firstName).text(); // clean XSS tags visually
    const cleanUserFullName = `${cleanFirstName} ${lastName}`;
    const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(cleanUserFullName)}&background=17a2b8&color=fff&rounded=true&bold=true`;

    $('#sidebarAvatarImg').attr('src', avatarUrl);
    $('#userNavbarAvatarImg').attr('src', avatarUrl);
    $('#userDropdownAvatarImg').attr('src', avatarUrl);
    
    $('#userNameDisplay').text(cleanUserFullName);
    $('#userDropdownName').text(cleanUserFullName);
    $('#sidebarUserName').text(cleanUserFullName);

    // Update dashboard metrics
    function updateDashboardStats() {
      $.ajax({
        url: '/api/catalogs',
        type: 'GET',
        success: function(res) {
          $('#catalogsCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/users',
        type: 'GET',
        success: function(res) {
          $('#usersCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/payments',
        type: 'GET',
        success: function(res) {
          $('#paymentsCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/notifications',
        type: 'GET',
        success: function(res) {
          $('#notificationsCount').text(res.length);
        }
      });
    }

    // Section Switching Handlers
    $('#nav-stats').click(function(e) {
      e.preventDefault();
      showSection('stats-section', 'nav-stats');
      updateDashboardStats();
    });
    $('#nav-catalogs-list').click(function(e) {
      e.preventDefault();
      showSection('catalogs-list-section', 'nav-catalogs-list');
      loadCatalogs();
    });
    $('#nav-add-catalog').click(function(e) {
      e.preventDefault();
      showSection('add-catalog-section', 'nav-add-catalog');
    });
    $('#nav-security').click(function(e) {
      e.preventDefault();
      showSection('security-section', 'nav-security');
    });
    $('#nav-users').click(function(e) {
      e.preventDefault();
      showSection('users-section', 'nav-users');
      loadUsers();
    });
    $('#nav-payments').click(function(e) {
      e.preventDefault();
      showSection('payments-section', 'nav-payments');
      loadPayments();
    });
    $('#nav-notifications').click(function(e) {
      e.preventDefault();
      showSection('notifications-section', 'nav-notifications');
      loadNotifications();
    });

    // Language switcher click events
    $('.lang-btn').click(function(e) {
      e.preventDefault();
      const lang = $(this).attr('data-lang');
      applyLanguage(lang);
      
      // Reload active tab data
      if ($('#nav-catalogs-list').hasClass('active')) loadCatalogs();
      if ($('#nav-users').hasClass('active')) loadUsers();
      if ($('#nav-payments').hasClass('active')) loadPayments();
      if ($('#nav-notifications').hasClass('active')) loadNotifications();
      updateDashboardStats();
    });

    // Initialize Localization
    initLocalization();
    updateDashboardStats();

    // Logout function
    $('#logoutBtn').click(function(e) {
      e.preventDefault();
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      window.location.href = '/login';
    });

    // Image Previews Event Listeners
    function readURL(input, imgElementId, placeholderId) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          $(`#${imgElementId}`).attr('src', e.target.result).show();
          $(`#${placeholderId}`).hide();
        }
        reader.readAsDataURL(input.files[0]);
      }
    }

    $('#verticalImage').change(function() {
      readURL(this, 'verticalPreviewImg', 'verticalPlaceholder');
    });

    $('#horizontalImage').change(function() {
      readURL(this, 'horizontalPreviewImg', 'horizontalPlaceholder');
    });

    // Load Catalogs Function
    window.loadCatalogs = function() {
      // Destroy existing datatable instance if it exists to allow full re-population
      if ($.fn.DataTable.isDataTable('#catalogsTable')) {
        $('#catalogsTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/catalogs',
        type: 'GET',
        success: function(catalogs) {
          $('#catalogsCount').text(catalogs.length);
          let rows = '';
          
          catalogs.forEach(catalog => {
            const date = new Date(catalog.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric'
            });
            
            // Map uploaded local file or absolute CDN url
            const verticalURL = catalog.thumbnailVertical.startsWith('https://cdn.biblecms.com') && !catalog.thumbnailVertical.includes('bible_vertical')
              ? '/uploads/' + catalog.thumbnailVertical.split('/').pop() 
              : catalog.thumbnailVertical;
              
            const horizontalURL = catalog.thumbnailHorizontal.startsWith('https://cdn.biblecms.com') && !catalog.thumbnailHorizontal.includes('bible_horizontal')
              ? '/uploads/' + catalog.thumbnailHorizontal.split('/').pop()
              : catalog.thumbnailHorizontal;

            const viewText = currentLang === 'tr' ? 'Görüntüle' : 'View';

            rows += `
              <tr>
                <td><span class="badge badge-dark">${catalog.id}</span></td>
                <td><strong>${catalog.name}</strong></td>
                <td><span class="text-secondary small">${catalog.description}</span></td>
                <td class="text-center">
                  <img src="${verticalURL}" class="img-thumbnail preview-trigger" style="max-height: 55px; object-fit: contain; cursor: pointer;" data-title="${catalog.name} - Cover" href="${verticalURL}" onerror="this.src='https://via.placeholder.com/60x80?text=Cover'">
                  <br>
                  <a href="${verticalURL}" class="btn btn-xs btn-link text-info mt-1 preview-trigger" data-title="${catalog.name} - Cover"><i class="fas fa-expand"></i> ${viewText} Cover</a>
                </td>
                <td class="text-center">
                  <img src="${horizontalURL}" class="img-thumbnail preview-trigger" style="max-height: 55px; object-fit: contain; cursor: pointer;" data-title="${catalog.name} - Banner" href="${horizontalURL}" onerror="this.src='https://via.placeholder.com/120x70?text=Banner'">
                  <br>
                  <a href="${horizontalURL}" class="btn btn-xs btn-link text-info mt-1 preview-trigger" data-title="${catalog.name} - Banner"><i class="fas fa-expand"></i> ${viewText} Banner</a>
                </td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
              </tr>
            `;
          });
          
          $('#catalogsTableBody').html(rows);

          // Build localization settings for DataTables
          const trLangConfig = {
            "search": "Ara:",
            "lengthMenu": "_MENU_ kayıt göster",
            "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
            "infoEmpty": "Kayıt yok",
            "infoFiltered": "(_MAX_ kayıt içerisinden filtrelendi)",
            "zeroRecords": "Eşleşen kayıt bulunamadı",
            "paginate": {
              "first": "İlk",
              "last": "Son",
              "next": "Sonraki",
              "previous": "Önceki"
            }
          };

          const enLangConfig = {
            "search": "Search:",
            "lengthMenu": "Show _MENU_ entries",
            "info": "Showing _START_ to _END_ of _TOTAL_ entries",
            "infoEmpty": "Showing 0 to 0 of 0 entries",
            "infoFiltered": "(filtered from _MAX_ total entries)",
            "zeroRecords": "No matching records found",
            "paginate": {
              "first": "First",
              "last": "Last",
              "next": "Next",
              "previous": "Previous"
            }
          };

          // Initialize DataTable with settings
          $('#catalogsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 5,
            "lengthMenu": [5, 10, 25, 50],
            "language": currentLang === 'tr' ? trLangConfig : enLangConfig
          });
        },
        error: function(xhr) {
          console.error('Failed to load catalogs', xhr);
        }
      });
    }

    // Add Catalog Form Submission (Multipart)
    $('#addCatalogForm').submit(function(e) {
      e.preventDefault();
      
      const submitBtn = $('#submitBtn');
      const savingText = currentLang === 'tr' ? 'Yükleniyor...' : 'Uploading...';
      submitBtn.attr('disabled', true).html(`<i class="fas fa-spinner fa-spin mr-1"></i> ${savingText}`);

      const formData = new FormData();
      formData.append('name', $('#catalogName').val());
      formData.append('description', $('#catalogDescription').val());
      formData.append('verticalImage', $('#verticalImage')[0].files[0]);
      formData.append('horizontalImage', $('#horizontalImage')[0].files[0]);

      $.ajax({
        url: '/api/catalogs',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
          const successHeader = currentLang === 'tr' ? 'Başarılı!' : 'Success!';
          const successMsg = locales[currentLang] ? locales[currentLang].successMessage : 'Success!';
          $('#add-catalog-alert').html(`
            <div class="alert alert-success alert-dismissible elevation-1">
              <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
              <h5><i class="icon fas fa-check-circle"></i> ${successHeader}</h5>
              ${successMsg}
            </div>
          `);
          
          // Reset form
          $('#addCatalogForm')[0].reset();
          
          // Reset preview boxes
          $('#verticalPreviewImg').hide();
          $('#verticalPlaceholder').show();
          $('#horizontalPreviewImg').hide();
          $('#horizontalPlaceholder').show();
          bsCustomFileInput.init();
          
          // Reload catalogs list
          loadCatalogs();
          
          // Switch to catalogs-list tab after short delay
          setTimeout(() => {
            showSection('catalogs-list-section', 'nav-catalogs-list');
            $('#add-catalog-alert').html('');
            submitBtn.attr('disabled', false).html(`<i class="fas fa-save mr-1"></i> ${locales[currentLang] ? locales[currentLang].saveUploadPublication : 'Save'}`);
          }, 1500);
        },
        error: function(xhr) {
          const failHeader = locales[currentLang] ? locales[currentLang].uploadFailed : 'Upload Failed';
          const message = xhr.responseJSON ? xhr.responseJSON.message : (currentLang === 'tr' ? 'Bir hata oluştu.' : 'An error occurred during upload.');
          $('#add-catalog-alert').html(`
            <div class="alert alert-danger alert-dismissible elevation-1">
              <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
              <h5><i class="icon fas fa-ban"></i> ${failHeader}</h5>
              ${message}
            </div>
          `);
          submitBtn.attr('disabled', false).html(`<i class="fas fa-save mr-1"></i> ${locales[currentLang] ? locales[currentLang].saveUploadPublication : 'Save'}`);
        }
      });
    });

    // Users Section Functions
    window.loadUsers = function() {
      if ($.fn.DataTable.isDataTable('#usersTable')) {
        $('#usersTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/users',
        type: 'GET',
        success: function(users) {
          let rows = '';
          users.forEach(u => {
            const date = new Date(u.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });
            const editLabel = currentLang === 'tr' ? 'Düzenle' : 'Edit';
            const deleteLabel = currentLang === 'tr' ? 'Sil' : 'Delete';
            
            rows += `
              <tr>
                <td><span class="badge badge-secondary">${u.id}</span></td>
                <td><strong>${u.firstName} ${u.lastName}</strong></td>
                <td><code>${u.email}</code></td>
                <td>${u.phoneNumber}</td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
                <td class="text-center">
                  <button class="btn btn-sm btn-info mr-1" onclick="openEditUserModal(${u.id}, '${escapeHtml(u.firstName)}', '${escapeHtml(u.lastName)}', '${escapeHtml(u.email)}', '${escapeHtml(u.phoneNumber)}')"><i class="fas fa-edit"></i> ${editLabel}</button>
                  <button class="btn btn-sm btn-danger" onclick="deleteUser(${u.id})"><i class="fas fa-trash"></i> ${deleteLabel}</button>
                </td>
              </tr>
            `;
          });
          $('#usersTableBody').html(rows);

          $('#usersTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "language": currentLang === 'tr' ? {
              "search": "Ara:",
              "lengthMenu": "_MENU_ kayıt göster",
              "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
              "zeroRecords": "Eşleşen kullanıcı bulunamadı"
            } : {
              "search": "Search:",
              "lengthMenu": "Show _MENU_ entries",
              "info": "Showing _START_ to _END_ of _TOTAL_ entries",
              "zeroRecords": "No matching users found"
            }
          });
          updateDashboardStats();
        },
        error: function(err) {
          console.error('Failed to load users', err);
        }
      });
    };

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/&/g, '&').replace(/</g, '<').replace(/>/g, '>').replace(/"/g, '"').replace(/'/g, '&#039;');
    }

    window.openEditUserModal = function(id, firstName, lastName, email, phoneNumber) {
      $('#editUserId').val(id);
      $('#editFirstName').val(firstName);
      $('#editLastName').val(lastName);
      $('#editEmail').val(email);
      $('#editPhoneNumber').val(phoneNumber);
      $('#editPassword').val('');
      $('#edit-user-alert').html('');
      $('#editUserModal').modal('show');
    };

    $('#editUserForm').submit(function(e) {
      e.preventDefault();
      const id = $('#editUserId').val();
      const payload = {
        firstName: $('#editFirstName').val(),
        lastName: $('#editLastName').val(),
        email: $('#editEmail').val(),
        phoneNumber: $('#editPhoneNumber').val()
      };
      const newPwd = $('#editPassword').val();
      if (newPwd) {
        payload.password = newPwd;
      }

      $.ajax({
        url: `/api/users/${id}`,
        type: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function() {
          $('#editUserModal').modal('hide');
          loadUsers();
        },
        error: function(xhr) {
          const msg = xhr.responseJSON ? xhr.responseJSON.message : 'Error updating user';
          $('#edit-user-alert').html(`<div class="alert alert-danger">${msg}</div>`);
        }
      });
    });

    window.deleteUser = function(id) {
      const confirmMsg = currentLang === 'tr' ? 'Bu kullanıcıyı silmek istediğinize emin misiniz?' : 'Are you sure you want to delete this user?';
      if (!confirm(confirmMsg)) return;

      $.ajax({
        url: `/api/users/${id}`,
        type: 'DELETE',
        success: function() {
          loadUsers();
        },
        error: function(xhr) {
          alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error deleting user');
        }
      });
    };

    // Payments Section Functions
    window.loadPayments = function() {
      if ($.fn.DataTable.isDataTable('#paymentsTable')) {
        $('#paymentsTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/payments',
        type: 'GET',
        success: function(payments) {
          let rows = '';
          payments.forEach(p => {
            const date = new Date(p.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });
            const statusBadge = p.status === 'completed' 
              ? '<span class="badge badge-success">Completed</span>' 
              : `<span class="badge badge-warning">${p.status}</span>`;

            rows += `
              <tr>
                <td><span class="badge badge-dark">${p.id}</span></td>
                <td><span class="badge badge-secondary">User #${p.userId}</span></td>
                <td><code>${p.userEmail}</code></td>
                <td><strong>${p.productId}</strong></td>
                <td><code>${p.amount.toFixed(2)}</code></td>
                <td><span class="badge badge-info">${p.currency}</span></td>
                <td>${statusBadge}</td>
                <td><span class="text-secondary font-weight-bold small">${p.transactionId}</span></td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
              </tr>
            `;
          });
          $('#paymentsTableBody').html(rows);

          $('#paymentsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "language": currentLang === 'tr' ? {
              "search": "Ara:",
              "lengthMenu": "_MENU_ kayıt göster",
              "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
              "zeroRecords": "Eşleşen ödeme bulunamadı"
            } : {
              "search": "Search:",
              "lengthMenu": "Show _MENU_ entries",
              "info": "Showing _START_ to _END_ of _TOTAL_ entries",
              "zeroRecords": "No matching payments found"
            }
          });
          updateDashboardStats();
        },
        error: function(err) {
          console.error('Failed to load payments', err);
        }
      });
    };

    // Notifications Section Functions
    window.loadNotifications = function() {
      if ($.fn.DataTable.isDataTable('#notificationsTable')) {
        $('#notificationsTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/notifications',
        type: 'GET',
        success: function(notifications) {
          let rows = '';
          notifications.forEach(n => {
            const date = new Date(n.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });
            const typeBadge = `<span class="badge badge-${n.type === 'danger' ? 'danger' : n.type === 'success' ? 'success' : n.type === 'warning' ? 'warning' : 'info'}">${n.type.toUpperCase()}</span>`;
            const deleteLabel = currentLang === 'tr' ? 'Sil' : 'Delete';
            
            rows += `
              <tr>
                <td><span class="badge badge-dark">${n.id}</span></td>
                <td><strong>${n.title}</strong></td>
                <td><span class="text-secondary small">${n.message}</span></td>
                <td>${typeBadge}</td>
                <td><code>${n.sentTo}</code></td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
                <td class="text-center">
                  <button class="btn btn-sm btn-danger" onclick="deleteNotification(${n.id})"><i class="fas fa-trash"></i> ${deleteLabel}</button>
                </td>
              </tr>
            `;
          });
          $('#notificationsTableBody').html(rows);

          $('#notificationsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "language": currentLang === 'tr' ? {
              "search": "Ara:",
              "lengthMenu": "_MENU_ kayıt göster",
              "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
              "zeroRecords": "Eşleşen bildirim bulunamadı"
            } : {
              "search": "Search:",
              "lengthMenu": "Show _MENU_ entries",
              "info": "Showing _START_ to _END_ of _TOTAL_ entries",
              "zeroRecords": "No matching notifications found"
            }
          });
          updateDashboardStats();
        },
        error: function(err) {
          console.error('Failed to load notifications', err);
        }
      });
    };

    $('#sendNotificationForm').submit(function(e) {
      e.preventDefault();
      const payload = {
        title: $('#notifTitle').val(),
        message: $('#notifMessage').val(),
        type: $('#notifType').val(),
        sentTo: $('#notifSentTo').val()
      };

      $.ajax({
        url: '/api/notifications',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function() {
          $('#sendNotificationForm')[0].reset();
          $('#notifSentTo').val('all');
          loadNotifications();
        },
        error: function(xhr) {
          const msg = xhr.responseJSON ? xhr.responseJSON.message : 'Error sending notification';
          $('#notification-alert').html(`<div class="alert alert-danger">${msg}</div>`);
        }
      });
    });

    window.deleteNotification = function(id) {
      const confirmMsg = currentLang === 'tr' ? 'Bu bildirimi silmek istediğinize emin misiniz?' : 'Are you sure you want to delete this notification?';
      if (!confirm(confirmMsg)) return;

      $.ajax({
        url: `/api/notifications/${id}`,
        type: 'DELETE',
        success: function() {
          loadNotifications();
        },
        error: function(xhr) {
          alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error deleting notification');
        }
      });
    };

    // Image Preview Modal Handler
    $(document).on('click', '.preview-trigger', function(e) {
      e.preventDefault();
      const imageUrl = $(this).attr('href') || $(this).attr('src');
      const title = $(this).attr('data-title') || 'Image Preview';
      $('#previewImageSrc').attr('src', imageUrl);
      $('#imagePreviewModalLabel').text(title);
      $('#imagePreviewModal').modal('show');
    });

  });
</script>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" role="dialog" aria-labelledby="editUserModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header bg-info">
        <h5 class="modal-title text-white font-weight-bold" id="editUserModalLabel">Edit User</h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <form id="editUserForm">
        <input type="hidden" id="editUserId">
        <div class="modal-body">
          <div id="edit-user-alert"></div>
          <div class="form-group">
            <label for="editFirstName" class="font-weight-bold" data-i18n="firstName">First Name</label>
            <input type="text" class="form-control" id="editFirstName" required>
          </div>
          <div class="form-group">
            <label for="editLastName" class="font-weight-bold" data-i18n="lastName">Last Name</label>
            <input type="text" class="form-control" id="editLastName" required>
          </div>
          <div class="form-group">
            <label for="editEmail" class="font-weight-bold" data-i18n="email">Email</label>
            <input type="email" class="form-control" id="editEmail" required>
          </div>
          <div class="form-group">
            <label for="editPhoneNumber" class="font-weight-bold" data-i18n="phoneNumber">Phone Number</label>
            <input type="text" class="form-control" id="editPhoneNumber" required>
          </div>
          <div class="form-group">
            <label for="editPassword" class="font-weight-bold" data-i18n="password">Password</label>
            <input type="password" class="form-control" id="editPassword" placeholder="Leave blank to keep unchanged">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal" data-i18n="close">Close</button>
          <button type="submit" class="btn btn-info" data-i18n="saveChanges">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1" role="dialog" aria-labelledby="imagePreviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content" style="background: transparent; border: none; box-shadow: none;">
      <div class="modal-header" style="border: none; padding: 0 0 10px 0;">
        <h5 class="modal-title text-white font-weight-bold" id="imagePreviewModalLabel">Image Preview</h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close" style="font-size: 30px; line-height: 24px; opacity: 0.8;">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body p-0 text-center">
        <img id="previewImageSrc" src="" class="img-fluid rounded shadow-lg" style="max-height: 80vh; max-width: 100%; object-fit: contain;">
      </div>
    </div>
  </div>
</div>

</body>
</html>