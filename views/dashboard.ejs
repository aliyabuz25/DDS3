          <span class="d-none d-md-inline" id="userNameDisplay">Loading...</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
          <!-- User image -->
          <li class="user-header bg-info">
            <img src="https://ui-avatars.com/api/?name=Admin&background=17a2b8&color=fff&rounded=true" class="img-circle elevation-2" alt="User Image" id="userDropdownAvatarImg">
            <p>
              <span id="userDropdownName">Administrator</span>
