    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar user panel -->
      <div class="user-panel mt-3 pb-3 mb-3 d-flex align-items-center">
        <div class="image">
          <img src="https://ui-avatars.com/api/?name=Admin&background=17a2b8&color=fff&rounded=true" class="img-circle elevation-2" alt="User Image" id="sidebarAvatarImg">
        </div>
        <div class="info">
          <a href="#" class="d-block" id="sidebarUserName" data-i18n="systemUser">System User</a>
