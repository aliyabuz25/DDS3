          <a href="#" class="dropdown-item lang-btn py-2" data-lang="tr">
            <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/tr.svg" style="width: 16px; margin-right: 8px;" alt="TR Flag"> Türkçe
          </a>
          <a href="#" class="dropdown-item lang-btn py-2" data-lang="de">
            <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/de.svg" style="width: 16px; margin-right: 8px;" alt="DE Flag"> Deutsch
          </a>
          <a href="#" class="dropdown-item lang-btn py-2" data-lang="es">
            <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/es.svg" style="width: 16px; margin-right: 8px;" alt="ES Flag"> Español
          </a>
          <a href="#" class="dropdown-item lang-btn py-2" data-lang="fr">
            <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/fr.svg" style="width: 16px; margin-right: 8px;" alt="FR Flag"> Français
          </a>
          <a href="#" class="dropdown-item lang-btn py-2" data-lang="it">
