  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0 font-weight-bold" id="pageTitle" style="color: #333;" data-i18n="dashboardOverview">Dashboard Overview</h1>
          </div>
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
              <li class="breadcrumb-item"><a href="#" onclick="$('#nav-stats').trigger('click'); return false;" data-i18n="home">Home</a></li>
              <li class="breadcrumb-item active" id="breadcrumbActive" data-i18n="dashboardOverview">Dashboard Overview</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
    <!-- /.content-header -->

    <!-- Main content -->
    <div class="content">
      <div class="container-fluid">
        
        <!-- Section 1: Stats Overview -->
        <div class="content-section" id="stats-section">
          <div class="row">
            <div class="col-lg-3 col-6">
              <div class="small-box bg-info">
                <div class="inner">
                  <h3 id="catalogsCount">0</h3>
                  <p data-i18n="totalCatalogItems">Total Catalog Items</p>
                </div>
                <div class="icon">
                  <i class="fas fa-book-open"></i>
                </div>
                <a href="#" class="small-box-footer" onclick="$('#nav-catalogs-list').trigger('click'); return false;"><span data-i18n="viewDetails">View Details</span> <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
            <div class="col-lg-3 col-6">
              <div class="small-box bg-success">
                <div class="inner">
                  <h3 id="usersCount">0</h3>
                  <p data-i18n="users">Users</p>
                </div>
                <div class="icon">
                  <i class="fas fa-users"></i>
                </div>
                <a href="#" class="small-box-footer" onclick="$('#nav-users').trigger('click'); return false;"><span data-i18n="viewDetails">View Details</span> <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
            <div class="col-lg-3 col-6">
              <div class="small-box bg-warning">
                <div class="inner" style="color: white !important;">
                  <h3 style="color: white !important;" id="paymentsCount">0</h3>
                  <p style="color: white !important;" data-i18n="payments">Payments</p>
                </div>
                <div class="icon">
                  <i class="fas fa-credit-card"></i>
                </div>
                <a href="#" class="small-box-footer" style="color: white !important;" onclick="$('#nav-payments').trigger('click'); return false;"><span data-i18n="viewDetails" style="color: white !important;">View Details</span> <i class="fas fa-arrow-circle-right" style="color: white !important;"></i></a>
              </div>
            </div>
            <div class="col-lg-3 col-6">
              <div class="small-box bg-danger">
                <div class="inner">
                  <h3 id="notificationsCount">0</h3>
                  <p data-i18n="notifications">Notifications</p>
                </div>
                <div class="icon">
                  <i class="fas fa-bell"></i>
                </div>
                <a href="#" class="small-box-footer" onclick="$('#nav-notifications').trigger('click'); return false;"><span data-i18n="viewDetails">View Details</span> <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
          </div>

          <!-- Welcome Jumbotron Card -->
          <div class="card card-primary card-outline">
            <div class="card-header d-flex align-items-center">
              <i class="fas fa-info-circle text-info mr-2" style="font-size: 18px;"></i>
              <h5 class="m-0 font-weight-bold" data-i18n="welcomeTitle">Visual Catalog System</h5>
            </div>
            <div class="card-body">
              <p class="card-text text-muted" style="font-size: 15px; line-height: 1.6;" data-i18n="welcomeText">
                Welcome to the CMS Admin Console. This user-friendly interface allows you to easily manage, filter, and organize visual catalog publications. All uploads automatically optimize and format to high-definition vertical/horizontal thumbnails. Security protocols like HTML injection protection and rate limit protection are active.
              </p>
              <div class="mt-3">
                <a href="#" class="btn btn-info mr-2" onclick="$('#nav-catalogs-list').trigger('click'); return false;">
                  <i class="fas fa-list mr-1"></i> <span data-i18n="browseCatalogList">Browse Catalog List</span>
                </a>
                <a href="#" class="btn btn-outline-secondary" onclick="$('#nav-add-catalog').trigger('click'); return false;">
                  <i class="fas fa-plus mr-1"></i> <span data-i18n="addPublication">Add Publication</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 2: Catalogs List -->
        <div class="content-section d-none" id="catalogs-list-section">
          <div class="card card-primary card-outline">
            <div class="card-header">
              <h3 class="card-title font-weight-bold text-dark m-0">
                <i class="fas fa-folder-open text-warning mr-1"></i> <span data-i18n="registeredVisualPublications">Registered Visual Publications</span>
              </h3>
            </div>
            <div class="card-body">
              <table id="catalogsTable" class="table table-bordered table-striped table-hover w-100">
                <thead>
                  <tr>
                    <th style="width: 50px;" data-i18n="id">ID</th>
                    <th data-i18n="publicationName">Publication Name</th>
                    <th data-i18n="description">Description</th>
                    <th style="width: 140px; text-align: center;" data-i18n="verticalCover">Vertical Cover (3:4)</th>
                    <th style="width: 140px; text-align: center;" data-i18n="horizontalCover">Horizontal Cover (16:9)</th>
                    <th style="width: 130px;" data-i18n="createdAt">Created At</th>
                  </tr>
                </thead>
                <tbody id="catalogsTableBody">
                  <!-- Loaded via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Section 3: Add Catalog Item -->
        <div class="content-section d-none" id="add-catalog-section">
          <div class="card card-primary">
            <div class="card-header">
              <h3 class="card-title font-weight-bold"><i class="fas fa-plus-circle mr-1"></i> <span data-i18n="addNewVisualPublication">Add New Visual Publication</span></h3>
            </div>
            <form id="addCatalogForm" enctype="multipart/form-data">
              <div class="card-body">
                <div id="add-catalog-alert"></div>
                
                <div class="row">
                  <div class="col-md-6">
                    <div class="form-group">
                      <label for="catalogName" class="font-weight-bold"><span data-i18n="publicationNameLabel">Publication Name</span> <span class="text-danger">*</span></label>
                      <div class="input-group">
                        <div class="input-group-prepend">
                          <span class="input-group-text"><i class="fas fa-tag"></i></span>
                        </div>
                        <input type="text" class="form-control" id="catalogName" name="name" placeholder="e.g. Visual Book Guide" required>
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-group">
                      <label for="catalogDescription" class="font-weight-bold"><span data-i18n="descriptionSummaryLabel">Description / Summary</span> <span class="text-danger">*</span></label>
                      <textarea class="form-control" id="catalogDescription" name="description" rows="1" placeholder="Enter short summary..." required style="height: 38px; min-height: 38px; max-height: 120px;"></textarea>
                    </div>
                  </div>
                </div>

                <hr class="my-4">

                <!-- Interactive cover previews -->
                <div class="row">
                  <!-- Vertical Cover file & preview -->
                  <div class="col-md-6 mb-3">
                    <label class="font-weight-bold d-block" data-i18n="verticalThumbnailCover">Vertical Thumbnail Cover *</label>
                    <div class="custom-file mb-3">
                      <input type="file" class="custom-file-input" id="verticalImage" name="verticalImage" accept="image/*" required>
                      <label class="custom-file-label" for="verticalImage" data-i18n="chooseVerticalImage">Choose vertical image...</label>
                    </div>
                    <div class="preview-box" id="verticalPreviewContainer">
                      <div class="preview-placeholder" id="verticalPlaceholder">
                        <i class="fas fa-portrait"></i>
                        <p class="m-0"><span data-i18n="verticalAspectRatio">Vertical Aspect Ratio (3:4 or Portrait)</span><br><span data-i18n="noImageSelected">No Image Selected</span></p>
                      </div>
                      <img id="verticalPreviewImg" class="preview-img" alt="Vertical Cover Preview">
                    </div>
                    <small class="form-text text-muted mt-1" data-i18n="acceptsFormats">Accepts PNG, JPG, JPEG, WEBP or GIF.</small>
                  </div>

                  <!-- Horizontal Cover file & preview -->
                  <div class="col-md-6 mb-3">
                    <label class="font-weight-bold d-block" data-i18n="horizontalBannerCover">Horizontal Banner Cover *</label>
                    <div class="custom-file mb-3">
                      <input type="file" class="custom-file-input" id="horizontalImage" name="horizontalImage" accept="image/*" required>
                      <label class="custom-file-label" for="horizontalImage" data-i18n="chooseHorizontalImage">Choose horizontal image...</label>
                    </div>
                    <div class="preview-box" id="horizontalPreviewContainer">
                      <div class="preview-placeholder" id="horizontalPlaceholder">
                        <i class="fas fa-image"></i>
                        <p class="m-0"><span data-i18n="horizontalAspectRatio">Horizontal Aspect Ratio (16:9 or Landscape)</span><br><span data-i18n="noImageSelected">No Image Selected</span></p>
                      </div>
                      <img id="horizontalPreviewImg" class="preview-img" alt="Horizontal Cover Preview">
                    </div>
                    <small class="form-text text-muted mt-1" data-i18n="acceptsFormats">Accepts PNG, JPG, JPEG, WEBP or GIF.</small>
                  </div>
                </div>

              </div>
              <!-- /.card-body -->

              <div class="card-footer bg-light d-flex justify-content-end">
                <button type="submit" class="btn btn-success px-4 elevation-1" id="submitBtn">
                  <i class="fas fa-save mr-1"></i> <span data-i18n="saveUploadPublication">Save & Upload Publication</span>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Section 4: Security Specs -->
        <div class="content-section d-none" id="security-section">
          <div class="row">
            <div class="col-md-6">
              <div class="card card-dark">
                <div class="card-header bg-dark">
                  <h3 class="card-title font-weight-bold text-white"><i class="fas fa-user-shield mr-1"></i> <span data-i18n="middlewareSecurityGuard">Middleware Security Guard</span></h3>
                </div>
                <div class="card-body">
                  <div class="d-flex align-items-start mb-3">
                    <i class="fas fa-shield-alt text-success mr-3 mt-1" style="font-size: 24px;"></i>
                    <div>
                      <h6 class="font-weight-bold m-0" data-i18n="helmetSecurity">Helmet Security Protection</h6>
                      <p class="text-muted small" data-i18n="helmetText">Protects from clickjacking, MIME sniffing, and enforces modern secure HTTP headers.</p>
                    </div>
                  </div>
                  <hr>
                  <div class="d-flex align-items-start mb-3">
                    <i class="fas fa-clock text-warning mr-3 mt-1" style="font-size: 24px;"></i>
                    <div>
                      <h6 class="font-weight-bold m-0" data-i18n="rateLimiterShield">Rate-Limiter Bruteforce Shield</h6>
                      <p class="text-muted small" data-i18n="rateLimiterText">Limits auth endpoints to maximum 5 calls per 15 minutes to guarantee database stability and security.</p>
                    </div>
                  </div>
                  <hr>
                  <div class="d-flex align-items-start">
                    <i class="fas fa-code-branch text-info mr-3 mt-1" style="font-size: 24px;"></i>
                    <div>
                      <h6 class="font-weight-bold m-0" data-i18n="strictSanitizer">Strict Input HTML/XSS Sanitizer</h6>
                      <p class="text-muted small" data-i18n="strictSanitizerText">All user inputs (first name, last name, phone, email, publication descriptions) are parsed to prevent malicious script code execution.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card card-info">
                <div class="card-header bg-info">
                  <h3 class="card-title font-weight-bold"><i class="fas fa-info-circle mr-1"></i> <span data-i18n="systemSchemaIntegration">System Schema & Integration</span></h3>
                </div>
                <div class="card-body">
                  <p class="text-muted" data-i18n="systemSchemaText">You can inspect full api configuration specs inside your workspace folders:</p>
                  <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                      <div>
                        <i class="fas fa-file-code text-primary mr-2"></i> <strong>openapi.json</strong>
                        <span class="d-block text-muted small">OpenAPI 3.0 API Schema Standard</span>
                      </div>
                      <span class="badge badge-primary badge-pill">JSON Specs</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                      <div>
                        <i class="fas fa-file-markdown text-success mr-2"></i> <strong>FETCH_DOCS.md</strong>
                        <span class="d-block text-muted small">Fetch multipart/form-data integrations</span>
                      </div>
                      <span class="badge badge-success badge-pill">Markdown Guide</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                      <div>
                        <i class="fas fa-vial text-warning mr-2"></i> <strong>test.js</strong>
                        <span class="d-block text-muted small">Automated integration testing suit</span>
                      </div>
                      <span class="badge badge-warning badge-pill text-white">Supertest</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- API Endpoints Card -->
          <div class="card card-primary card-outline mt-3">
            <div class="card-header">
              <h5 class="m-0 font-weight-bold text-dark"><i class="fas fa-network-wired text-primary mr-1"></i> API Endpoints Specification</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-bordered table-striped m-0">
                  <thead>
                    <tr class="bg-light text-secondary small font-weight-bold">
                      <th style="width: 100px;">Method</th>
                      <th>Endpoint</th>
                      <th>Description</th>
                      <th>Payload / Parameters</th>
                      <th>Headers</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><span class="badge badge-success px-2 py-1">POST</span></td>
                      <td><code>/api/auth/register</code></td>
                      <td>Register a new user with name, email, phone number, and password. Inputs are HTML-sanitized.</td>
                      <td><code>{ firstName, lastName, email, phoneNumber, password }</code></td>
                      <td><code>Content-Type: application/json</code></td>
                    </tr>
                    <tr>
                      <td><span class="badge badge-success px-2 py-1">POST</span></td>
                      <td><code>/api/auth/login</code></td>
                      <td>Authenticate and retrieve a JWT access token. Bruteforce rate-limited (5 requests / 15 mins).</td>
                      <td><code>{ email, password }</code></td>
                      <td><code>Content-Type: application/json</code></td>
                    </tr>
                    <tr>
                      <td><span class="badge badge-info px-2 py-1">GET</span></td>
                      <td><code>/api/catalogs</code></td>
                      <td>List all visual catalog publications in the database.</td>
                      <td><em>None</em></td>
                      <td><code>User-Agent: bible-appclient</code></td>
                    </tr>
                    <tr>
                      <td><span class="badge badge-success px-2 py-1">POST</span></td>
                      <td><code>/api/catalogs</code></td>
                      <td>Add a new visual publication. Dual image uploads (vertical/horizontal thumbnails).</td>
                      <td>FormData: <code>name</code>, <code>description</code>, <code>verticalImage</code>, <code>horizontalImage</code></td>
                      <td><code>User-Agent: bible-appclient</code></td>
                    </tr>
                    <tr>
                      <td><span class="badge badge-info px-2 py-1">GET</span></td>
                      <td><code>/api/locales</code></td>
                      <td>Retrieve the dictionary containing multi-language translation locales dynamically.</td>
                      <td><em>None</em></td>
                      <td><code>User-Agent: bible-appclient</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>

        <!-- Section 5: Users List -->
        <div class="content-section d-none" id="users-section">
          <div class="card card-info card-outline">
            <div class="card-header">
              <h3 class="card-title font-weight-bold text-dark m-0">
                <i class="fas fa-users text-info mr-1"></i> <span data-i18n="users">Users</span>
              </h3>
            </div>
            <div class="card-body">
              <table id="usersTable" class="table table-bordered table-striped table-hover w-100">
                <thead>
                  <tr>
                    <th style="width: 50px;">ID</th>
                    <th><span data-i18n="firstName">First Name</span> & <span data-i18n="lastName">Last Name</span></th>
                    <th data-i18n="email">Email</th>
                    <th data-i18n="phoneNumber">Phone Number</th>
                    <th style="width: 130px;" data-i18n="createdAt">Created At</th>
                    <th style="width: 150px; text-align: center;" data-i18n="action">Action</th>
