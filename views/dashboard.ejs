            <div class="col-md-8">
              <div class="card card-primary card-outline">
                <div class="card-header">
                  <h3 class="card-title font-weight-bold text-dark m-0">
                    <i class="fas fa-bell text-info mr-1"></i> <span data-i18n="notifications">Notifications</span>
                  </h3>
                </div>
                <div class="card-body">
                  <table id="notificationsTable" class="table table-bordered table-striped table-hover w-100">
                    <thead>
                      <tr>
                        <th style="width: 50px;">ID</th>
                        <th data-i18n="notificationTitle">Title</th>
                        <th data-i18n="notificationMessage">Message</th>
                        <th data-i18n="notificationType">Type</th>
                        <th data-i18n="sentTo">Sent To</th>
                        <th style="width: 130px;" data-i18n="createdAt">Created At</th>
                        <th style="width: 80px; text-align: center;" data-i18n="action">Action</th>
                      </tr>
                    </thead>
                    <tbody id="notificationsTableBody">
                      <!-- Loaded via AJAX -->
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
